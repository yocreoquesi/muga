{
  "manifest_version": 3,
  "name": "MUGA — Make URLs Great Again",
  "short_name": "MUGA",
  "version": "1.0.2",
  "description": "Clean URLs, no tracking, no unwanted referrals. You decide what happens to each link.",

  "permissions": [
    "storage",
    "tabs",
    "contextMenus",
    "declarativeNetRequest",
    "clipboardWrite"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/browser-polyfill.min.js", "content/cleaner.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "MUGA"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": ["onboarding/onboarding.html", "privacy/privacy.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
